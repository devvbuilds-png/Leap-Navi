# Database — Supabase Postgres.
# DATABASE_URL = the POOLED connection string (Supabase "Transaction" pooler, host contains "pooler", port 6543).
#                Used by the running app. Must end with: ?pgbouncer=true&connection_limit=1
# DIRECT_URL   = the DIRECT connection string (port 5432). Used only to create tables / seed.
# Get both from Supabase: Project → Connect button (top bar) → ORMs / Prisma.
DATABASE_URL="postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# LLM intelligence (optional — app runs fully on the deterministic engine without any key).
# Provider is auto-detected: OpenAI is used if OPENAI_API_KEY is set, else Anthropic.
# Force one explicitly with LLM_PROVIDER=openai | anthropic.

# OpenAI / ChatGPT
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Anthropic (alternative)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Optional: pin the provider regardless of which keys are present
# LLM_PROVIDER="openai"
